xport default __webpack_public_path__ + \"static/media/heatmap.310d76b2.svg\";","import React from 'react';\nimport './Landing.scss';\nimport Icons from '../Icons/Icons.js';\nimport Heatmap from '../Images/heatmap.svg';\n\n\n\n/* 'c' is 'container' */\n/* 'col' is 'column'  */\n/* 'b' is 'body' */\n\nfunction Landing() {\n  return (\n    <div className=\"landing\">\n      <div className=\"landing_c\">\n\n        <div className=\"landing_c_col\">\n          <div className=\"landing_c_col1_c\">\n            <div className=\"smalltext\">Hello! I'm</div>\n              <h1 className=\"largetext\">Aavar Khatiwoda</h1>\n              <div className=\"smalltext\">\n              A computer science student who<br/>\n              loves to explore new technologies<br/><br/>\n              I teach Python and math to<br/>\n              young students, and love fixing<br/>\n              computers and and game systems,<br/>\n              and doing Minecraft server hosting<br/><br/>\n              <Icons />\n              </div>\n          </div>\n        </div>\n\n        <div className=\"landing_c_col\">\n          <div className=\"landing_c_col2_c\">\n            <img src={Heatmap} alt=\"heatmap\" className=\"landing_c_col2_c_image\" />\n          </div>\n        </div>\n\n      </div>\n    </div>\n  )\n}\n\nexport default Landing;\n","import React from 'react';\nimport './SectionHeading.scss';\n/*import Icons from '../Icons/Icons.js';*/\n\n\n/* 'c' is 'container' */\n\nfunction SectionHeading(props) {\n  return (\n    <div className=\"sectionheading\">\n      <div className=\"sectionheading_c\">\n        <h1 className=\"largetext\">{props.name}</h1>\n      </div>\n    </div>\n  );\n}\n\nexport default SectionHeading;\n","import React from 'react';\nimport './AboutMe.scss';\nimport SectionHeading from '../SectionHeading/SectionHeading.js';\n\n/* 'c' is 'container' */\n/* 'col' is 'column' */\n/* 'b' is 'body' */\n\nfunction ShowSkills() {\n  const technologies = [\n    {\n      name:\"Languages\",\n      content:[\"Python\",\"Java\",\"C\",\"HTML / SCSS\",\"JavaScript\",\"\"]\n    },\n    {\n      name:\"Frameworks\",\n      content:[\"React\",\"Flask\"]\n    },\n    {\n      name:\"Tools\",\n      content:[\"Github\",\"Terminal\",\"NEAT Python\",\"Inventor\",\"R / Octave\",\"MATLAB\"]\n    },\n    {\n      name:\"Additional Skills\",\n      content:[\"Data Structures\",\"Algorithms\",\"Web Hosting, Mgmt\",\"Communication\",\"Teaching\"]\n    }\n  ];\n\n  return (\n    <div className=\"aboutme_c_col\">\n      {technologies.map(item => (\n        <div className=\"aboutme_c_col_contents\">\n          <div className=\"aboutme_c_col_title\">\n            <div className=\"smalltext\">\n              {item.name}\n            </div>\n          </div>\n          <div className=\"aboutme_c_col_b\">\n            {item.content.map(item2 => (\n              <ul>\n                <li>\n                  <div className=\"smalltext\">\n                    {item2}\n                  </div>\n                </li>\n              </ul>\n            ))}\n          </div>\n        </div>\n      ))}\n    </div>\n  );\n}\n\nfunction AboutMe() {\n  return (\n    <div className=\"aboutme\">\n      <SectionHeading name=\"Technical Skills\" />\n      <div className=\"aboutme_c\">\n        <ShowSkills />\n      </div>\n    </div>\n  );\n}\n\nexport default AboutMe;\n","import React from 'react';\nimport './Footer.scss';\nimport Icons from '../Icons/Icons.js';\n\n\nfunction Footer() {\n  return (\n    <div className=\"footer\">\n\n      <div className=\"footer_c\">\n        <div className=\"footer_space\"></div>\n        <h1 className=\"largetext\">Aavar Khatiwoda</h1>\n        <div className=\"smalltext\">Let's Get in Touch</div>\n        <div className=\"footer_space\"></div>\n        <Icons />\n        <div className=\"footer_space\"></div>\n      </div>\n    </div>\n  );\n}\n\nexport default Footer;\n","import Landing from './Components/Landing/Landing.js';\ni